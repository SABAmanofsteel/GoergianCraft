{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": "gui",
        "model": {
          "type": "minecraft:model",
          "model": "georgiancraft:item/salamuri_gui"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "on_false": {
        "type": "minecraft:model",
        "model": "georgiancraft:item/salamuri"
      },
      "on_true": {
        "type": "minecraft:model",
        "model": "georgiancraft:item/tooting_salamuri"
      },
      "property": "minecraft:using_item"
    }
  }
}